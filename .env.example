# Database (Neon / Supabase / Railway)
# Use a pooled connection URL for DATABASE_URL (PgBouncer)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"
# Direct connection for migrations (no pooler)
DATABASE_DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Resend — https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Upstash Redis — https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxx"

# Health check secret (any random string)
HEALTH_SECRET="xxxxxxxxxxxxxxxxxxxx"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to true in CI to skip env validation
# SKIP_ENV_VALIDATION=true
